{
  "name": "moauth",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev:connect": "npm --workspace @moauth/connect run dev",
    "build:connect": "npm --workspace @moauth/connect run build",
    "test": "npm run test --workspaces --if-present",
    "test:connect": "npm --workspace @moauth/connect run test",
    "test:connect-contract": "npm --workspace @moauth/connect-contract run test"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  }
}
