# MoAuth self-hosted Zitadel — local development defaults.
# Copy to .env and edit before first `docker compose up`.
# The masterkey cannot be changed after first start without data loss.

# === Zitadel core ===
# Generate with: tr -dc 'A-Za-z0-9' </dev/urandom | head -c 32
ZITADEL_MASTERKEY=ReplaceMeWith32RandomCharacters0000

# Public surface — must match the URL users type in the browser.
# Use 127.0.0.1.sslip.io so Zitadel can issue TLS-less redirect URIs that browsers accept.
ZITADEL_EXTERNALDOMAIN=127.0.0.1.sslip.io
ZITADEL_EXTERNALPORT=8081
ZITADEL_EXTERNALSECURE=false

# === Postgres ===
ZITADEL_POSTGRES_PASSWORD=moauth_zitadel_pg_dev_password

# === Bootstrap master admin ===
ZITADEL_BOOTSTRAP_USERNAME=moauth-admin
ZITADEL_BOOTSTRAP_PASSWORD=MoAuthAdminPass2026!
ZITADEL_BOOTSTRAP_EMAIL=admin@127.0.0.1.sslip.io
ZITADEL_ORG_NAME=MoAuth
