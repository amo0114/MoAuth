# MoAuth staging Docker Compose template.
# Copy to deploy/staging/.env on the server and replace every change-me value.
# Do not commit the real .env file.

# Public HTTPS hosts served by Caddy.
CONNECT_HOST=connect.staging.example.com
ACCOUNT_HOST=account.staging.example.com
SUBBOOST_HOST=app.staging.example.com
ZITADEL_HOST=id.staging.example.com
ACME_EMAIL=ops@example.com

# Runtime images are built by GitHub Actions and published to GHCR.
# Pin MOAUTH_IMAGE_TAG to sha-<commit> for reproducible staging/prod deploys.
MOAUTH_IMAGE_REGISTRY=ghcr.io/amo0114
MOAUTH_IMAGE_TAG=main

# Zitadel self-hosted core.
# Generate with: openssl rand -base64 48
ZITADEL_MASTERKEY=change-me-keep-stable-after-first-boot
ZITADEL_POSTGRES_PASSWORD=change-me-zitadel-postgres-password
ZITADEL_ORG_NAME=MoAuth Staging
ZITADEL_BOOTSTRAP_USERNAME=admin
ZITADEL_BOOTSTRAP_PASSWORD=change-me-admin-password
ZITADEL_BOOTSTRAP_EMAIL=admin@example.com
ZITADEL_SERVICE_USER=connect-service

# After first Zitadel bootstrap, copy the generated PAT into this value.
# See docs/deploy/moauth-staging-docker-runbook.md.
ZITADEL_SERVICE_USER_TOKEN=change-me-zitadel-service-user-pat
ZITADEL_ORG_ID=
ZITADEL_PROJECT_ID=

# Connect production issuer signing.
CONNECT_SIGNING_PRIVATE_KEY_FILE_HOST=./secrets/connect-signing/private.pem
MOAUTH_CONNECT_ID_TOKEN_SIGNING_KID=moauth-connect-staging-1
MOAUTH_CONNECT_ID_TOKEN_SIGNING_ALG=RS256

# MoAuth runtime secrets.
# Generate each with: openssl rand -base64 48
MOAUTH_CONNECT_SESSION_SECRET=change-me-connect-session-secret
MOAUTH_CONNECT_TRANSACTION_SECRET=change-me-connect-transaction-secret
MOAUTH_CONNECT_ADMIN_API_TOKEN=change-me-connect-admin-api-token
MOAUTH_ACCOUNT_SESSION_SECRET=change-me-account-session-secret
MOAUTH_HANDOFF_INTERNAL_TOKEN=change-me-shared-handoff-token
MOAUTH_HANDOFF_STORE_SECRET=change-me-handoff-store-secret

# File stores are single-instance staging defaults.
# Before horizontal scaling, migrate to DB-backed stores or sign off the single-instance limit.
MOAUTH_CLIENT_REGISTRY_STORE=file
MOAUTH_AUTHORIZED_APPS_STORE=file

# Account admin subjects are Zitadel subject IDs, comma-separated.
MOAUTH_ACCOUNT_ADMIN_SUBJECTS=
MOAUTH_CONSOLE_ZITADEL_SYNC=true

# SubBoost database and runtime.
SUBBOOST_POSTGRES_DB=subboost
SUBBOOST_POSTGRES_USER=subboost
SUBBOOST_POSTGRES_PASSWORD=change-me-subboost-postgres-password
SUBBOOST_DATABASE_URL=postgresql://subboost:change-me-subboost-postgres-password@subboost-db:5432/subboost
SUBBOOST_ENCRYPTION_KEY=change-me-subboost-encryption-key
SUBBOOST_JWT_SECRET=change-me-subboost-jwt-secret
SUBBOOST_CRON_SECRET=change-me-subboost-cron-secret
SUBBOOST_MOAUTH_TX_SECRET=change-me-subboost-moauth-tx-secret

# Must match the SubBoost OIDC app in Zitadel and the MoAuth client registry.
MOAUTH_CONNECT_CLIENT_ID=change-me-subboost-client-id
MOAUTH_CONNECT_CLIENT_SECRET=

# Optional build metadata.
APP_RELEASE_VERSION=
APP_BUILD_SHA=
APP_VERSION=
APP_VERSION_TOKEN=
