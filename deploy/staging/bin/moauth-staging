#!/usr/bin/env bash
# MoAuth staging operator CLI — init, bootstrap, deploy, preflight.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

COMPOSE_BASE=(docker compose --env-file .env -f docker-compose.yml)
COMPOSE_LOCAL=("${COMPOSE_BASE[@]}" -f docker-compose.build.yml)

# Commits that fixed known production pitfalls (instance-host headers, deactivate POST).
REQUIRED_FIX_SHAS=(baad793 0436dd9)

usage() {
  cat <<'EOF'
MoAuth staging operator CLI

Usage:
  ./bin/moauth-staging init --domain <base-domain> [--admin-email <email>] [--force]
  ./bin/moauth-staging bootstrap          # start Zitadel, sync PAT + org id into .env
  ./bin/moauth-staging deploy [--local|--ghcr] [--no-cache] [--service <name>]
  ./bin/moauth-staging preflight          # smoke checks for known deployment pitfalls
  ./bin/moauth-staging status

Examples:
  ./bin/moauth-staging init --domain oai-o.com --admin-email admin@oai-o.com
  ./bin/moauth-staging bootstrap
  ./bin/moauth-staging deploy --local --no-cache account
  ./bin/moauth-staging preflight

Environment (.env):
  MOAUTH_DEPLOY_MODE=auto|ghcr|local   default: auto (ARM64 -> local, else ghcr)
  MOAUTH_IMAGE_TAG=sha-<commit>|local    pin immutable GHCR tag for reproducible deploys
EOF
}

log() { printf '[moauth-staging] %s\n' "$*"; }
die() { log "ERROR: $*"; exit 1; }

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

rand_b64() { openssl rand -base64 48 | tr -d '\n'; }
rand_masterkey() { tr -dc 'A-Za-z0-9' </dev/urandom | head -c 32; }

load_env() {
  [[ -f .env ]] || die ".env not found. Run: ./bin/moauth-staging init --domain <domain>"
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
}

env_get() {
  local key="$1"
  grep -E "^${key}=" .env 2>/dev/null | head -1 | cut -d= -f2- || true
}

env_set() {
  local key="$1" value="$2"
  if grep -qE "^${key}=" .env; then
    sed -i "s|^${key}=.*|${key}=${value}|" .env
  else
    printf '%s=%s\n' "$key" "$value" >>.env
  fi
}

detect_deploy_mode() {
  local mode="${MOAUTH_DEPLOY_MODE:-auto}"
  case "$mode" in
    ghcr|local) printf '%s' "$mode"; return ;;
    auto)
      local arch
      arch="$(uname -m)"
      if [[ "$arch" == "aarch64" || "$arch" == "arm64" ]]; then
        printf 'local'
      else
        printf 'ghcr'
      fi
      ;;
    *) die "invalid MOAUTH_DEPLOY_MODE=$mode (use auto, ghcr, or local)" ;;
  esac
}

git_head_sha() {
  if git -C "$ROOT/../.." rev-parse --short HEAD >/dev/null 2>&1; then
    git -C "$ROOT/../.." rev-parse --short HEAD
  else
    printf 'unknown'
  fi
}

git_has_fixes() {
  local repo
  repo="$(cd "$ROOT/../.." && pwd)"
  local sha
  for sha in "${REQUIRED_FIX_SHAS[@]}"; do
    if ! git -C "$repo" merge-base --is-ancestor "$sha" HEAD 2>/dev/null; then
      return 1
    fi
  done
  return 0
}

cmd_init() {
  local domain="" admin_email="" force=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain) domain="$2"; shift 2 ;;
      --admin-email) admin_email="$2"; shift 2 ;;
      --force) force=1; shift ;;
      *) die "unknown init arg: $1" ;;
    esac
  done
  [[ -n "$domain" ]] || die "init requires --domain <base-domain>"

  if [[ -f .env && "$force" -ne 1 ]]; then
    die ".env already exists. Re-run with --force to overwrite."
  fi

  need_cmd openssl
  need_cmd npm

  local connect_host="connect.${domain}"
  local account_host="account.${domain}"
  local subboost_host="app.${domain}"
  local zitadel_host="id.${domain}"
  admin_email="${admin_email:-admin@${domain}}"

  mkdir -p secrets/connect-signing bootstrap

  if [[ ! -f secrets/connect-signing/private.pem ]]; then
    log "generating Connect signing key..."
    npm run moauth:generate-signing-keys -- --out-dir "$ROOT/secrets/connect-signing" --kid moauth-connect-staging-1 >/dev/null
  fi

  local subboost_db_pass zitadel_db_pass
  subboost_db_pass="$(rand_b64)"
  zitadel_db_pass="$(rand_b64)"

  cat >.env <<EOF
# Generated by ./bin/moauth-staging init on $(date -Iseconds)
# Base domain: ${domain}

CONNECT_HOST=${connect_host}
ACCOUNT_HOST=${account_host}
SUBBOOST_HOST=${subboost_host}
ZITADEL_HOST=${zitadel_host}
ACME_EMAIL=${admin_email}

NEXT_PUBLIC_IDENTITY_PRODUCT_NAME=Aura
NEXT_PUBLIC_IDENTITY_ACCOUNT_NAME=Aura 账号中心
NEXT_PUBLIC_IDENTITY_GATEWAY_NAME=Connect
NEXT_PUBLIC_IDENTITY_PUBLIC_DOMAIN=${connect_host}
NEXT_PUBLIC_IDENTITY_ACCOUNT_URL=https://${account_host}
NEXT_PUBLIC_IDENTITY_CONNECT_URL=https://${connect_host}
NEXT_PUBLIC_IDENTITY_SUPPORT_EMAIL=${admin_email}
NEXT_PUBLIC_IDENTITY_SLOGAN=入本源，见真知。

MOAUTH_DEPLOY_MODE=auto
MOAUTH_IMAGE_REGISTRY=ghcr.io/amo0114
MOAUTH_IMAGE_TAG=local

ZITADEL_MASTERKEY=$(rand_masterkey)
ZITADEL_POSTGRES_PASSWORD=${zitadel_db_pass}
ZITADEL_ORG_NAME=Aura
ZITADEL_BOOTSTRAP_USERNAME=admin
ZITADEL_BOOTSTRAP_PASSWORD=$(rand_b64)
ZITADEL_BOOTSTRAP_EMAIL=${admin_email}
ZITADEL_SERVICE_USER=connect-service
ZITADEL_SERVICE_USER_TOKEN=change-me-run-bootstrap
ZITADEL_ORG_ID=
ZITADEL_PROJECT_ID=

CONNECT_SIGNING_PRIVATE_KEY_FILE_HOST=./secrets/connect-signing/private.pem
MOAUTH_CONNECT_ID_TOKEN_SIGNING_KID=moauth-connect-staging-1
MOAUTH_CONNECT_ID_TOKEN_SIGNING_ALG=RS256

MOAUTH_CONNECT_SESSION_SECRET=$(rand_b64)
MOAUTH_CONNECT_TRANSACTION_SECRET=$(rand_b64)
MOAUTH_CONNECT_ADMIN_API_TOKEN=$(rand_b64)
MOAUTH_ACCOUNT_SESSION_SECRET=$(rand_b64)
MOAUTH_HANDOFF_INTERNAL_TOKEN=$(rand_b64)
MOAUTH_HANDOFF_STORE_SECRET=$(rand_b64)

MOAUTH_CLIENT_REGISTRY_STORE=file
MOAUTH_AUTHORIZED_APPS_STORE=file
MOAUTH_ACCOUNT_ADMIN_SUBJECTS=
MOAUTH_CONSOLE_ZITADEL_SYNC=true

SUBBOOST_POSTGRES_DB=subboost
SUBBOOST_POSTGRES_USER=subboost
SUBBOOST_POSTGRES_PASSWORD=${subboost_db_pass}
SUBBOOST_DATABASE_URL=postgresql://subboost:${subboost_db_pass}@subboost-db:5432/subboost
SUBBOOST_ENCRYPTION_KEY=$(rand_b64)
SUBBOOST_JWT_SECRET=$(rand_b64)
SUBBOOST_CRON_SECRET=$(rand_b64)
SUBBOOST_MOAUTH_TX_SECRET=$(rand_b64)

MOAUTH_CONNECT_CLIENT_ID=change-me-subboost-client-id
MOAUTH_CONNECT_CLIENT_SECRET=
EOF

  chmod 600 .env
  log "created .env for ${domain}"
  log "next: ./bin/moauth-staging bootstrap"
}

curl_zitadel() {
  local token="$1" host="$2" org_id="${3:-}"
  local args=(
    -fsS
    -H "Authorization: Bearer ${token}"
    -H "Content-Type: application/json"
    -H "x-zitadel-instance-host: ${host}"
    -H "x-zitadel-public-host: ${host}"
    -H "X-Forwarded-Host: ${host}"
    -H "X-Forwarded-Proto: https"
  )
  if [[ -n "$org_id" ]]; then
    args+=(-H "x-zitadel-orgid: ${org_id}")
  fi
  curl "${args[@]}" "$@"
}

cmd_bootstrap() {
  load_env
  need_cmd curl
  mkdir -p bootstrap

  log "starting zitadel-db + zitadel..."
  "${COMPOSE_BASE[@]}" up -d zitadel-db zitadel

  log "waiting for zitadel healthy..."
  local i
  for i in $(seq 1 60); do
    if curl -fsS "http://127.0.0.1:18080/debug/ready" >/dev/null 2>&1; then
      break
    fi
    sleep 2
  done
  curl -fsS "http://127.0.0.1:18080/debug/ready" >/dev/null || die "zitadel not ready after 120s"

  local pat_file="$ROOT/bootstrap/connect-service.pat"
  [[ -f "$pat_file" ]] || die "missing ${pat_file}. First-init only — check zitadel logs."
  local pat
  pat="$(tr -d '\n\r ' <"$pat_file")"
  [[ -n "$pat" ]] || die "connect-service PAT file is empty"

  env_set ZITADEL_SERVICE_USER_TOKEN "$pat"
  log "synced ZITADEL_SERVICE_USER_TOKEN from bootstrap/connect-service.pat"

  if [[ -z "${ZITADEL_ORG_ID:-}" ]]; then
    local org_json org_id=""
    org_json="$(curl_zitadel "$pat" "$ZITADEL_HOST" "" "http://127.0.0.1:18080/management/v1/orgs/me" || true)"
    if command -v jq >/dev/null 2>&1; then
      org_id="$(printf '%s' "$org_json" | jq -r '.org.id // .id // empty' 2>/dev/null || true)"
    else
      org_id="$(printf '%s' "$org_json" | sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
    fi
    if [[ -n "$org_id" ]]; then
      env_set ZITADEL_ORG_ID "$org_id"
      log "synced ZITADEL_ORG_ID=${org_id}"
    else
      log "WARN: could not auto-detect ZITADEL_ORG_ID — set manually in .env"
    fi
  fi

  log "bootstrap done. Still manual once: ZITADEL_PROJECT_ID, SubBoost OIDC app, MOAUTH_CONNECT_CLIENT_ID"
  log "grant connect-service IAM_LOGIN_CLIENT in Zitadel Console if login finalize fails"
  log "next: ./bin/moauth-staging deploy"
}

cmd_deploy() {
  local mode_arg="" no_cache="" service=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --local) mode_arg="local"; shift ;;
      --ghcr) mode_arg="ghcr"; shift ;;
      --no-cache) no_cache=1; shift ;;
      --service) service="$2"; shift 2 ;;
      *) die "unknown deploy arg: $1" ;;
    esac
  done

  load_env
  local mode="${mode_arg:-$(detect_deploy_mode)}"
  local head_sha
  head_sha="$(git_head_sha)"

  if ! git_has_fixes; then
    log "WARN: git HEAD may be missing fixes ${REQUIRED_FIX_SHAS[*]} — pull latest main before deploy"
  fi

  case "$mode" in
    local)
      export MOAUTH_IMAGE_TAG=local
      local build_args=(build)
      [[ -n "$no_cache" ]] && build_args+=(--no-cache)
      [[ -n "$service" ]] && build_args+=("$service")
      log "local build (MOAUTH_IMAGE_TAG=local)..."
      "${COMPOSE_LOCAL[@]}" "${build_args[@]}"
      if [[ -n "$service" ]]; then
        "${COMPOSE_LOCAL[@]}" up -d --force-recreate "$service"
      else
        "${COMPOSE_LOCAL[@]}" up -d --force-recreate
      fi
      ;;
    ghcr)
      if [[ "${MOAUTH_IMAGE_TAG:-main}" == "local" || "${MOAUTH_IMAGE_TAG:-}" == "change-me"* ]]; then
        export MOAUTH_IMAGE_TAG="sha-$(git -C "$ROOT/../.." rev-parse HEAD 2>/dev/null || echo main)"
        env_set MOAUTH_IMAGE_TAG "$MOAUTH_IMAGE_TAG"
        log "pinned MOAUTH_IMAGE_TAG=${MOAUTH_IMAGE_TAG}"
      fi
      log "pulling GHCR images (tag=${MOAUTH_IMAGE_TAG})..."
      if [[ -n "$service" ]]; then
        "${COMPOSE_BASE[@]}" pull "$service"
        "${COMPOSE_BASE[@]}" up -d --force-recreate "$service"
      else
        "${COMPOSE_BASE[@]}" pull
        "${COMPOSE_BASE[@]}" up -d --force-recreate
      fi
      ;;
  esac

  log "deploy complete (mode=${mode}, git=${head_sha})"
  log "running preflight..."
  cmd_preflight || true
}

cmd_preflight() {
  load_env
  need_cmd curl
  need_cmd jq

  local failed=0
  check() {
    if "$@"; then
      log "OK  $*"
    else
      log "FAIL $*"
      failed=1
    fi
  }

  check curl -fsS "http://127.0.0.1:18080/debug/ready" >/dev/null
  check curl -fsS "http://127.0.0.1:13000/.well-known/openid-configuration" >/dev/null
  if curl -fsS "http://127.0.0.1:13002/api/health/ready" | jq -e '.ok == true' >/dev/null; then
    log "OK  curl -fsS http://127.0.0.1:13002/api/health/ready | jq -e '.ok == true'"
  else
    log "FAIL curl -fsS http://127.0.0.1:13002/api/health/ready | jq -e '.ok == true'"
    failed=1
  fi

  if [[ -n "${NEXT_PUBLIC_IDENTITY_ACCOUNT_URL:-}" && -n "${NEXT_PUBLIC_IDENTITY_CONNECT_URL:-}" ]]; then
    log "OK  NEXT_PUBLIC_IDENTITY_* URLs set"
  else
    log "FAIL NEXT_PUBLIC_IDENTITY_* URLs empty — run init or set in .env"
    failed=1
  fi

  if docker compose --env-file .env ps account 2>/dev/null | grep -qE 'running|Up'; then
    if docker compose --env-file .env exec -T account grep -q 'x-zitadel-instance-host' /app/packages/zitadel-client/src/config.js 2>/dev/null; then
      log "OK  instance-host header fix present"
    else
      log "FAIL missing x-zitadel-instance-host fix — rebuild account from baad793+"
      failed=1
    fi
    if docker compose --env-file .env exec -T account grep -A1 'deactivateHumanUser' /app/packages/zitadel-client/src/users.js 2>/dev/null | grep -q postUserAction; then
      log "OK  deactivate uses POST"
    else
      log "FAIL deactivate still uses PUT — rebuild account from 0436dd9+"
      failed=1
    fi
  fi

  if [[ -n "${ZITADEL_SERVICE_USER_TOKEN:-}" && "${ZITADEL_SERVICE_USER_TOKEN}" != change-me* ]]; then
    docker compose --env-file .env exec -T account node <<'NODE' >/tmp/moauth-preflight-deact.txt 2>&1 || true
const token = process.env.ZITADEL_SERVICE_USER_TOKEN;
const orgId = process.env.ZITADEL_ORG_ID;
const host = (process.env.ZITADEL_ISSUER || '').replace(/^https?:\/\//, '');
const hdrs = {
  Authorization: 'Bearer ' + token,
  'Content-Type': 'application/json',
  'x-zitadel-orgid': orgId,
  'x-zitadel-instance-host': host,
  'x-zitadel-public-host': host,
  'X-Forwarded-Host': host,
  'X-Forwarded-Proto': 'https',
};
(async () => {
  const email = 'preflight-' + Date.now() + '@example.com';
  const create = await fetch('http://zitadel:8080/v2/users/human', {
    method: 'POST', headers: hdrs,
    body: JSON.stringify({
      username: email,
      profile: { givenName: 'Pre', familyName: 'Flight', displayName: 'Preflight' },
      email: { email, sendCode: {} },
      password: { password: 'TestPassword123!', changeRequired: false },
    }),
  });
  if (!create.ok) { console.log('create-fail', create.status); process.exit(0); }
  const userId = (await create.json()).userId;
  const deact = await fetch('http://zitadel:8080/v2/users/' + userId + '/deactivate', {
    method: 'POST', headers: hdrs, body: '{}',
  });
  console.log('deactivate', deact.status);
  await fetch('http://zitadel:8080/v2/users/' + userId, { method: 'DELETE', headers: hdrs });
})();
NODE
    if grep -q 'deactivate 200' /tmp/moauth-preflight-deact.txt 2>/dev/null; then
      log "OK  Zitadel deactivate POST smoke test"
    else
      log "FAIL Zitadel deactivate smoke test: $(cat /tmp/moauth-preflight-deact.txt 2>/dev/null | tr '\n' ' ')"
      failed=1
    fi
  else
    log "FAIL ZITADEL_SERVICE_USER_TOKEN not set — run bootstrap"
    failed=1
  fi

  local reg_mode
  reg_mode="$(docker compose --env-file .env exec -T account cat /app/data/registration-config.json 2>/dev/null | jq -r '.mode // empty' || true)"
  if [[ -n "$reg_mode" ]]; then
    log "OK  registration mode=${reg_mode}"
  fi

  if [[ "$failed" -ne 0 ]]; then
    die "preflight failed — fix items above before serving traffic"
  fi
  log "preflight passed"
}

cmd_status() {
  load_env 2>/dev/null || true
  "${COMPOSE_BASE[@]}" ps
}

main() {
  need_cmd docker
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    init) cmd_init "$@" ;;
    bootstrap) cmd_bootstrap "$@" ;;
    deploy) cmd_deploy "$@" ;;
    preflight|check) cmd_preflight "$@" ;;
    status) cmd_status "$@" ;;
    help|-h|--help) usage ;;
    *) usage; die "unknown command: $cmd" ;;
  esac
}

main "$@"
